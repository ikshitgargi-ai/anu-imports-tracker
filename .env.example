# ============================================================================
# Anu Imports Tracker — environment variables
# Set these in the Render dashboard (Service → Environment). Copy this file's
# KEYS; fill the VALUES from where each line says.
# ============================================================================

# --- REQUIRED ---------------------------------------------------------------
# A NEW, SEPARATE Neon Postgres database — NEVER the NB tracker's database.
# Create at neon.tech → New Project "anu-imports" → copy the pooled connection
# string. Strip any "&channel_binding=require" the app does this automatically.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# LCBO Sale-of-Data login — the SAME account as the NB tracker (lcbo-tracker).
# Open the lcbo-tracker service on Render → Environment → reveal these three →
# paste the identical values here.
SOD_USER=
SOD_PASSWORD=
SOD_AGENT_ID=1113

# Random secret shared between the web service and the daily cron job.
# Generate once:  openssl rand -hex 32
SOD_CRON_TOKEN=

# --- RECOMMENDED ------------------------------------------------------------
# Protects /api/admin/* and the one-tap "Load 148 stores" button.
# Generate once:  openssl rand -hex 32
ADMIN_TOKEN=

# Shelf-photo emails + daily backup. Free at resend.com (3,000 emails/mo).
RESEND_API_KEY=
ALERT_EMAIL_TO=ikshit@anuspirits.com
ALERT_EMAIL_FROM=alerts@anuspirits.com

# Which website is allowed to call this backend (the Anu frontend on Vercel).
# Default already includes anu-imports-web.vercel.app + localhost; override only
# if you use a custom domain.
CORS_ORIGINS=https://anu-imports-web.vercel.app,http://localhost:3000,http://localhost:3001

# --- OPTIONAL ---------------------------------------------------------------
FLASK_DEBUG=false
TZ=America/Toronto
SENTRY_DSN=

# ============================================================================
# ONE-TIME history migration (optional — only if you want past SOD data on day 1).
# Run LOCALLY from your Mac, not on Render:
#   export SOURCE_DATABASE_URL='<the NB tracker / lcbo-tracker Neon URL — READ ONLY>'
#   export TARGET_DATABASE_URL='<this app's NEW Neon URL>'
#   python3 scripts/migrate_history.py
# It copies the 766 stores + history for the 9 Anu SKUs only. Read-only on the
# source; refuses to run if SOURCE == TARGET. Skip it and the app fills in from
# the nightly SOD sync going forward.
# ============================================================================
