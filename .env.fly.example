# Copy this to .env.fly and fill in the values.
# Values come from the lcbo-tracker Render service (same SOD account) —
# Render → lcbo-tracker → Environment tab → click "Reveal" on each value —
# EXCEPT DATABASE_URL, which must be a NEW separate Neon database.
#
#   cp .env.fly.example .env.fly
#   # edit .env.fly with the real values
#   bash deploy-to-fly.sh
#
# Do NOT commit .env.fly to git. It's in .gitignore.

# === REQUIRED ===
# NEW separate Neon database — never the NB tracker's database.
DATABASE_URL=postgresql://...neon.tech/anu_imports?sslmode=require
# Same SOD account as the lcbo-tracker service — copy the current values.
SOD_USER=
SOD_PASSWORD=
SOD_AGENT_ID=1113
SOD_CRON_TOKEN=

# === RECOMMENDED — for /ask AI assistant ===
ANTHROPIC_API_KEY=

# === RECOMMENDED — for email alerts + daily backup + tasting digest ===
# Sign up: https://resend.com (free, 3,000 emails/mo)
RESEND_API_KEY=
ALERT_EMAIL_TO=ikshit@anuspirits.com
ALERT_EMAIL_FROM=alerts@anuspirits.com
TASTING_DIGEST_TO=ikshit@anuspirits.com,sales@anuspirits.com

# === RECOMMENDED — protects /api/admin/* endpoints ===
# Generate: openssl rand -hex 32
ADMIN_TOKEN=

# === REQUIRED — frontend domain for CORS ===
CORS_ORIGINS=https://anu-imports-web.vercel.app,http://localhost:3001,http://localhost:3000

# === DEFAULTS ===
FLASK_DEBUG=false
TZ=America/Toronto
